{minimum_otp_vsn, "24.0"}.

{project_plugins, [rebar3_hex]}.

{erl_opts, [warnings_as_errors,
            debug_info,
            warn_untyped_record]}.

{deps, [getopt]}.

{dialyzer, [
    {plt_extra_apps, [getopt, syntax_tools, eunit]},
    {exclude_mods, [cuttlefish_rebar_plugin, cuttlefish_unit]}
]}.

%% This is a library: all exported functions are part of the public API and
%% will appear "unused" within the project itself, so exports_not_used is
%% dropped. undefined_function_calls covers the same ground as
%% undefined_functions with the added benefit of showing the caller, so
%% undefined_functions is redundant and also dropped.
%% cuttlefish_rebar_plugin calls rebar2 functions not present at build time;
%% cuttlefish_unit calls bbmustache/mustache conditionally at runtime.
%% Both are excluded from Dialyzer for the same reasons.
{xref_checks, [undefined_function_calls, locals_not_used]}.
{xref_ignores, [cuttlefish_rebar_plugin, cuttlefish_unit]}.

{escript_emu_args, "%%! -escript main cuttlefish_escript +S 1 +A 0\n"}.
{escript_incl_apps, [getopt, cuttlefish]}.
{escript_main_app, cuttlefish}.

{provider_hooks, [{post, [{compile, {default, escriptize}}]}]}.

{eunit_opts, [verbose]}.
{cover_enabled, true}.
{cover_print_enabled, true}.
{cover_export_enabled, true}.

{hex, [{doc, edoc}]}.

{profiles, [{dev, [{deps, [neotoma]},
                   {plugins, [rebar3_neotoma_plugin]}]},
            {test, [{deps, [bbmustache, proper]}]}]}.
