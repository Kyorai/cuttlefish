{minimum_otp_vsn, "24.0"}.

{project_plugins, [rebar3_hex]}.

{erl_opts, [warnings_as_errors,
            debug_info,
            warn_untyped_record]}.

{deps, [getopt]}.

{dialyzer, [
    {plt_extra_apps, [getopt, syntax_tools, eunit]},
    {exclude_mods, [cuttlefish_rebar_plugin, cuttlefish_unit]}
]}.

%% This is a library, so some "unused" functions are
%% a part of the public API.
%%
%% Projects such as `cuttlefish_unit`
%% functions absent at build time.
{xref_checks, [undefined_function_calls, locals_not_used]}.
{xref_ignores, [cuttlefish_rebar_plugin, cuttlefish_unit]}.

{escript_emu_args, "%%! -escript main cuttlefish_escript +S 1 +A 0\n"}.
{escript_incl_apps, [getopt, cuttlefish]}.
{escript_main_app, cuttlefish}.

{provider_hooks, [{post, [{compile, {default, escriptize}}]}]}.

{eunit_opts, [verbose]}.
{cover_enabled, true}.
{cover_print_enabled, true}.
{cover_export_enabled, true}.

{hex, [{doc, edoc}]}.

{profiles, [{dev, [{deps, [neotoma]},
                   {plugins, [rebar3_neotoma_plugin]}]},
            {test, [{deps, [bbmustache, proper]}]}]}.
